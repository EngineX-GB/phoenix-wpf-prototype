<Window x:Class="phoenix_prototype.Reports"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:phoenix_prototype"
        mc:Ignorable="d"
        Background="#1A1A1A"
        WindowStyle="None"
        Title="News"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        Height="450" Width="800">


    <Window.Resources>
        <local:AvailabilityToBrushConverter x:Key="AvailabilityToBrushConverter" />
        <Style x:Key="WatermarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="2">

                            <Grid>
                                <!-- Actual text -->
                                <ScrollViewer x:Name="PART_ContentHost"/>

                                <!-- Placeholder -->
                                <TextBlock x:Name="Watermark"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="DarkGray"
                                   Margin="4,2,0,0"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsKeyboardFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        
        
        
    </Window.Resources>



    <DockPanel>

        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top"
                Background="Black"
                Height="20"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Text="News"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontSize="10"/>

                <!-- Close Button -->
                <Button Grid.Column="1"
                        Content="⨯"
                        Width="40"
                        Background="Black"
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontWeight="Bold"
                        Click="CloseButton_Click"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        />

            </Grid>
        </Border>

        <!-- Custom Toolbar -->
        <Border DockPanel.Dock="Top" Background="#222222" Padding="2">
            <Border.Resources>
                <Style TargetType="Button" x:Key="DarkButton">
                    <Setter Property="Background" Value="Black"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding" Value="3,3"/>
                    <Setter Property="Margin" Value="0,0,1,0"/>

                    <!-- Fixed size -->
                    <Setter Property="Width" Value="25"/>
                    <Setter Property="Height" Value="25"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#444"/>
                                    </Trigger>

                                    <!-- Pressed -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#555"/>
                                    </Trigger>

                                    <!-- Disabled -->
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#333"/>
                                        <Setter Property="Foreground" Value="#777"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>





                    <Style.Triggers>
                        <!-- Hover effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#555555"/>
                        </Trigger>
                    </Style.Triggers>


                </Style>
            </Border.Resources>
            <StackPanel Orientation="Horizontal">
                <TextBox Width="120" Name="Username"
                     Style="{StaticResource WatermarkTextBox}"
                     Tag="Username"
                     KeyDown="SearchField_KeyDown"
                     FontSize="10"
                     Margin="0,0,5,0"/>
                <Button Content="Search" Style="{StaticResource DarkButton}" Width="30" FontSize="8" Margin="0,0,5,0" ToolTip="Search" Click="RefreshButton_Click"/>
                <Button Content="|◀◀" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate from the start" Click="RefreshButton_Click"/>
                <Button Content="◀" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate from the start" Click="RefreshButton_Click"/>
                <Button Content="▶" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate Forward" Click="RefreshButton_Click"/>
                <Button Content="▶▶|" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate Forward" Click="RefreshButton_Click"/>

            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
            Background="#222"
            Height="22"
            BorderThickness="0">
            <Grid>
                <TextBlock x:Name="StatusText"
                   Text="Ready"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   Foreground="White"
                   FontSize="10"/>
            </Grid>
        </Border>
        <Grid>
            <TabControl>
                <TabItem Header="Home">
                    <TextBlock Text="Welcome to the Home tab" Margin="10"/>
                </TabItem>

                <TabItem Header="Settings">
                    <StackPanel Margin="10">
                        <TextBlock Text="Settings go here"/>
                        <Button Content="Save"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="About">
                    <TextBlock Text="About this app" Margin="10"/>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>


</Window>
