<Window x:Class="phoenix_prototype.Reports"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:phoenix_prototype"
        mc:Ignorable="d"
        Background="#1A1A1A"
        WindowStyle="None"
        Title="News"
        ShowInTaskbar="True"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        Height="450" Width="800">


    <Window.Resources>
        <local:AvailabilityToBrushConverter x:Key="AvailabilityToBrushConverter" />
        <Style x:Key="WatermarkTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#242424"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="2">

                            <Grid>
                                <!-- Actual text -->
                                <ScrollViewer x:Name="PART_ContentHost"/>

                                <!-- Placeholder -->
                                <TextBlock x:Name="Watermark"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="DarkGray"
                                   Margin="4,2,0,0"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Text" Value=""/>
                                    <Condition Property="IsKeyboardFocused" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#333"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,0,2,0"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="3"
                        Padding="6,3">
                            <!-- This shows the tab HEADER -->
                            <ContentPresenter
                        ContentSource="Header"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- Selected tab -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3A3A3A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#666"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#444"/>
                            </Trigger>

                            <!-- Disabled -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#777"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>



    <DockPanel>

        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top"
                Background="Black"
                Height="20"
                MouseDown="TitleBar_MouseDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Text="News"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontSize="10"/>

                <!-- Close Button -->
                <Button Grid.Column="1"
                        Content="⨯"
                        Width="40"
                        Background="Black"
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontWeight="Bold"
                        Click="CloseButton_Click"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        />

            </Grid>
        </Border>

        <!-- Custom Toolbar -->
        <Border DockPanel.Dock="Top" Background="#222222" Padding="2">
            <Border.Resources>
                <Style TargetType="Button" x:Key="DarkButton">
                    <Setter Property="Background" Value="Black"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding" Value="3,3"/>
                    <Setter Property="Margin" Value="0,0,1,0"/>

                    <!-- Fixed size -->
                    <Setter Property="Width" Value="25"/>
                    <Setter Property="Height" Value="25"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#444"/>
                                    </Trigger>

                                    <!-- Pressed -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#555"/>
                                    </Trigger>

                                    <!-- Disabled -->
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#333"/>
                                        <Setter Property="Foreground" Value="#777"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>





                    <Style.Triggers>
                        <!-- Hover effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#555555"/>
                        </Trigger>
                    </Style.Triggers>


                </Style>
            </Border.Resources>
            <StackPanel Orientation="Horizontal">
                <TextBox Width="120" Name="UserID"
                     Style="{StaticResource WatermarkTextBox}"
                     Tag="User ID"
                     KeyDown="SearchField_KeyDown"
                     FontSize="10"
                     Margin="0,0,5,0"/>
                <Button Content="Search" Style="{StaticResource DarkButton}" Width="30" FontSize="8" Margin="0,0,5,0" ToolTip="Search" Click="SearchButton_Click"/>
                <Button Content="|◀◀" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate from the start" />
                <Button Content="◀" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate from the start"/>
                <Button Content="▶" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate Forward" Click="NavigateNextPageResults_Click"/>
                <Button Content="▶▶|" Style="{StaticResource DarkButton}" FontSize="8" ToolTip="Navigate Forward"/>

            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
            Background="#222"
            Height="22"
            BorderThickness="0">
            <Grid>
                <TextBlock x:Name="StatusText"
                   Text="Ready"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   Foreground="White"
                   FontSize="10"/>
            </Grid>
        </Border>
        <Grid>
            <TabControl>
                <TabItem Header="Feedback">

                    <DataGrid x:Name="DataGridWatchlist" 
                          ItemsSource="{Binding FeedbackEntries}"
                          AutoGenerateColumns="False"
                          Background="#1A1A1A"
                          Foreground="White"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          BorderBrush="#444"
                          BorderThickness="1"
                          IsReadOnly="True">

                        <DataGrid.Resources>
                            <!-- Dark ScrollBar Style -->
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <!-- Track background -->
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="Black"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ScrollBar">
                                            <Grid Background="#1A1A1A">
                                                <Track Name="PART_Track"
                               IsDirectionReversed="True">
                                                    <Track.Thumb>
                                                        <Thumb Background="Black" BorderBrush="Black" BorderThickness="0.5"/>
                                                    </Track.Thumb>
                                                </Track>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>

                        <!-- this is needed to double override the colour for selecting a row - default is blue, but set it to grey-->
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Background" Value="#1A1A1A"/>
                                <Setter Property="Foreground" Value="White"/>

                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                        <!-- Selected cell color -->
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#777777"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.CellStyle>

                        <!-- Header Style -->
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Black"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#444"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="FontSize" Value="10"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <!-- Row Style -->
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="Black"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="FontSize" Value="10"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#333333"/>
                                        <!-- Dark grey -->
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Rating Date" Binding="{Binding RatingDate}" Width="100" />
                            <DataGridTextColumn Header="Rating" Binding="{Binding Rating}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Rating}" Value="UNKNOWN">
                                                <Setter Property="Foreground" Value="DarkGray"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Rating}" Value="NEGATIVE">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Rating}" Value="POSITIVE">
                                                <Setter Property="Foreground" Value="GreenYellow"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Rating}" Value="NEUTRAL">
                                                <Setter Property="Foreground" Value="DarkGray"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Feedback" Binding="{Binding Feedback}" Width="*"  />
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <TabItem Header="Service Reports">
                    <DataGrid x:Name="DataGridServiceReports" 
                         ItemsSource="{Binding ServiceReportHeadlineEntries}"
                         AutoGenerateColumns="False"
                         Background="#1A1A1A"
                         Foreground="White"
                         GridLinesVisibility="None"
                         HeadersVisibility="Column"
                         BorderBrush="#444"
                         BorderThickness="1"
                         IsReadOnly="True">

                            <DataGrid.Resources>
                                <!-- Dark ScrollBar Style -->
                                <Style TargetType="ScrollBar">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <!-- Track background -->
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="Black"/>

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ScrollBar">
                                                <Grid Background="#1A1A1A">
                                                    <Track Name="PART_Track" IsDirectionReversed="True">
                                                        <Track.Thumb>
                                                            <Thumb Background="Black" BorderBrush="Black" BorderThickness="0.5"/>
                                                        </Track.Thumb>
                                                    </Track>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>

                            <!-- this is needed to double override the colour for selecting a row - default is blue, but set it to grey-->
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="#1A1A1A"/>
                                    <Setter Property="Foreground" Value="White"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#333333"/>
                                            <!-- Selected cell color -->
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="BorderBrush" Value="#777777"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <!-- Header Style -->
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="Black"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#444"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="10"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <!-- Row Style -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Black"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#333"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="FontSize" Value="10"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#333333"/>
                                            <!-- Dark grey -->
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Meet Date" Binding="{Binding MeetDate}" Width="100" />
                            <DataGridTextColumn Header="Rating" Binding="{Binding ReportRating}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="White"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ReportRating}" Value="NONE">
                                                <Setter Property="Foreground" Value="DarkGray"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ReportRating}" Value="NEGATIVE">
                                                <Setter Property="Foreground" Value="Red"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ReportRating}" Value="POSITIVE">
                                                <Setter Property="Foreground" Value="GreenYellow"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ReportRating}" Value="NEUTRAL">
                                                <Setter Property="Foreground" Value="DarkGray"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Headline" Binding="{Binding Headline}" Width="*"  />
                            </DataGrid.Columns>
                        </DataGrid>

                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>


</Window>
