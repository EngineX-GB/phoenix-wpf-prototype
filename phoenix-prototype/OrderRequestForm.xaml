<local:PhoenixThemedWindow x:Class="phoenix_prototype.OrderRequestForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:phoenix_prototype"
        mc:Ignorable="d"
        Background="#1A1A1A"
        Title="Order Entry" Height="550" Width="530"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <Style x:Key="WatermarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3">

                            <Grid>
                                <!-- Actual text -->
                                <ScrollViewer x:Name="PART_ContentHost"/>

                                <!-- Watermark -->
                                <TextBlock x:Name="Watermark"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="#777"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>
    
    <DockPanel>

        <Grid Margin="5" Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
                <!-- Notes row shrinks -->
                <RowDefinition Height="Auto"/>
                <!-- Market Price -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- =======================
            FORM AREA
          ======================= -->

            <Grid Margin="10" Grid.Row="0" Name="AssetDetailsLegend">
                <!-- Outer border -->
                <Border BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#1A1A1A"
                    Padding="15,20,15,15"/>

                <!-- Floating legend label -->
                <Label Content="Asset Details"
                    Background="#1A1A1A"
                    Foreground="White"
                    Margin="10,0,0,0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"/>

                <!-- Content inside the group -->
                <StackPanel Margin="5,30,30,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="ID:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="Enter UserID..." />
                        <Label Grid.Row="1" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Name:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="Auto-populated..." />
                        <Label Grid.Row="2" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Location:" />
                        <TextBox Grid.Row="2" Grid.Column="1" BorderBrush="DarkGray" Margin="0,3,0,3" BorderThickness="1" Style="{StaticResource WatermarkTextBox}" Tag="Auto-populated.." />
                    </Grid>
                </StackPanel>
            </Grid>


            <Grid Margin="10" Grid.Row="1" Name="OrderDetailsLegend">
                <!-- Outer border -->
                <Border BorderBrush="#555"
                    BorderThickness="1"
                    CornerRadius="4"
                    Background="#1A1A1A"
                    Padding="15,20,15,15"/>

                <!-- Floating legend label -->
                <Label Content="Order Details"
                    Background="#1A1A1A"
                    Foreground="White"
                    Margin="10,0,0,0"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"/>

                <!-- Content inside the group -->
                <StackPanel Margin="5,30,30,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Quantity:"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="Enter Quantity" />
                        <Label Grid.Row="1" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Surplus:"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="Auto-populated..." />
                        <Label Grid.Row="2" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Deductions:" />
                        <TextBox Grid.Row="2" Grid.Column="1" BorderBrush="DarkGray" Margin="0,3,0,3" BorderThickness="1" Style="{StaticResource WatermarkTextBox}" Tag="Auto-populated.." />

                        <Label Grid.Row="0" Grid.Column="2" Foreground="DarkGray" Margin="0,3,3,3" Content="Trade Date:"/>
                        <TextBox Grid.Row="0" Grid.Column="3" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="YYYY-MM-DD" />
                        <Label Grid.Row="1" Grid.Column="2" Foreground="DarkGray" Margin="0,3,3,3" Content="Trade Time:" />
                        <TextBox Grid.Row="1" Grid.Column="3" BorderBrush="DarkGray" Margin="0,3,0,3" BorderThickness="1" Style="{StaticResource WatermarkTextBox}" Tag="HH:mm:ss" />
                        <Label Grid.Row="2" Grid.Column="2" Foreground="DarkGray" Margin="0,3,3,3" Content="Order Mode:" />

                        <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal" Width="Auto">
                            <Border BorderBrush="DarkGray"
                                    x:Name="ProposedBorder"
                                BorderThickness="1"
                                CornerRadius="4"
                                Background="#333"
                                Padding="3">
                                <Label Name="ProposedMode" Content="Proposed" Background="ForestGreen" Foreground="White" MouseDown="ProposedOrderMode_Click" />
                            </Border>
                            <Border BorderBrush="DarkGray"
                                BorderThickness="1"
                                    x:Name="CommittedBorder"
                                Background="#333"
                                Padding="3">
                                <Label Name="CommittedMode" Content="Committed" Background="#333" Foreground="White"  MouseDown="CommittedOrderMode_Click"/>
                            </Border>
                        </StackPanel>
                        
                    </Grid>
                </StackPanel>
            </Grid>


                <!-- Content inside the group -->
            <StackPanel Grid.Row="2" Margin="10,0,10,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Foreground="DarkGray" Margin="0,0,3,0" Content="Notes:" />
                    <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Margin="0,3,0,3"
                         Style="{StaticResource WatermarkTextBox}"
                         Tag="Enter notes..."
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Height="80" />

                </Grid>
            </StackPanel>


            <StackPanel Margin="10,0,10,0" Grid.Row="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Row="0" Grid.Column="0" LastChildFill="False" HorizontalAlignment="Right">
                        <Label Content="Market Price" Foreground="LightGray" Margin="0,0,5,0"/>
                        <Label Content="158.00 GBP" Foreground="LightGray"/>
                    </DockPanel>

                </Grid>
            </StackPanel>


            <!-- =======================
            BUTTON BAR
          ======================= -->
            <StackPanel Grid.Row="4"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   Margin="0,5,0,0">

                <Button Content="Cancel"
                   Width="80"
                   Margin="0,0,5,5"
                   Background="#333"
                   Foreground="White"
                   BorderBrush="#555"/>

                <Button Content="Submit Order"
                   Width="80"
                   Height="30"
                   Margin="0,0,5,5"
                   Background="DodgerBlue"
                   Foreground="White"
                   BorderBrush="#555"/>

            </StackPanel>
        </Grid>


    </DockPanel>

</local:PhoenixThemedWindow>
