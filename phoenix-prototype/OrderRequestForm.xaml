<local:PhoenixThemedWindow x:Class="phoenix_prototype.OrderRequestForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:phoenix_prototype"
        mc:Ignorable="d"
        Background="#1A1A1A"
        Title="Order Entry" Height="450" Width="500"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <Style x:Key="WatermarkTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#333"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="DarkGray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="3">

                            <Grid>
                                <!-- Actual text -->
                                <ScrollViewer x:Name="PART_ContentHost"/>

                                <!-- Watermark -->
                                <TextBlock x:Name="Watermark"
                                   Text="{TemplateBinding Tag}"
                                   Foreground="#777"
                                   Margin="5,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   Visibility="Collapsed"/>
                            </Grid>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Window.Resources>
    
    <DockPanel>

        <Grid Margin="20" Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <!-- Form -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- =======================
            FORM AREA
          ======================= -->

            <StackPanel Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="ID:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="Enter UserID..." />
                    <Label Grid.Row="1" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Name:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Margin="0,3,0,3" Style="{StaticResource WatermarkTextBox}" Tag="Auto-populated..." />
                    <Label Grid.Row="2" Grid.Column="0" Foreground="DarkGray" Margin="0,3,3,3" Content="Location:" />
                    <TextBox Grid.Row="2" Grid.Column="1" BorderBrush="DarkGray" Margin="0,3,0,3" BorderThickness="1" Style="{StaticResource WatermarkTextBox}" Tag="Auto-populated.." />
                </Grid>


            </StackPanel>
            
            <!-- =======================
            BUTTON BAR
          ======================= -->
            <StackPanel Grid.Row="1"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">

                <Button Content="Cancel"
                   Width="80"
                   Margin="0,0,5,5"
                   Background="#333"
                   Foreground="White"
                   BorderBrush="#555"/>

                <Button Content="Submit Order"
                   Width="80"
                   Height="30"
                   Margin="0,0,5,5"
                   Background="DodgerBlue"
                   Foreground="White"
                   BorderBrush="#555"/>

            </StackPanel>
        </Grid>


    </DockPanel>

</local:PhoenixThemedWindow>
