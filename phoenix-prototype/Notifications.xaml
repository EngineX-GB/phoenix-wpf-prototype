<Window x:Class="phoenix_prototype.Notifications"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:phoenix_prototype"
        mc:Ignorable="d"
        Background="#1A1A1A"
        WindowStyle="None"
        Title="Notifications"
        ShowInTaskbar="False"
        ResizeMode="CanResize">

    <DockPanel>

        <!-- Custom Title Bar -->
        <Border DockPanel.Dock="Top"
                Height="20"
                MouseDown="TitleBar_MouseDown">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#444444" Offset="0" />
                    <!-- Grey -->
                    <GradientStop Color="#000000" Offset="1" />
                    <!-- Black -->
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <TextBlock Text="Notifications"
                           VerticalAlignment="Center"
                           Margin="10,0,0,0"
                           Foreground="White"
                           FontSize="10"/>

                <!-- Close Button -->
                <Button Grid.Column="1"
                        Content="⨯"
                        Width="40"
                        Background="Black"
                        Foreground="White"
                        BorderBrush="Transparent"
                        FontWeight="Bold"
                        Click="CloseButton_Click"
                        Padding="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        />

            </Grid>
        </Border>

        <!-- Custom Toolbar -->
        <Border DockPanel.Dock="Top" Background="#222222" Padding="2">
            <Border.Resources>
                <Style TargetType="Button" x:Key="DarkButton">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="Lightgray"/>
                    <Setter Property="BorderBrush" Value="#444"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding" Value="3,3"/>
                    <Setter Property="Margin" Value="0,0,1,0"/>

                    <!-- Fixed size -->
                    <Setter Property="Width" Value="25"/>
                    <Setter Property="Height" Value="25"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <!-- Hover -->
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#444"/>
                                    </Trigger>

                                    <!-- Pressed -->
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#555"/>
                                    </Trigger>

                                    <!-- Disabled -->
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="border" Property="Background" Value="#333"/>
                                        <Setter Property="Foreground" Value="#777"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>


                    <Style.Triggers>
                        <!-- Hover effect -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#555555"/>
                        </Trigger>
                    </Style.Triggers>


                </Style>
            </Border.Resources>
            <StackPanel Orientation="Horizontal">
                <Button Content="✚" Style="{StaticResource DarkButton}" ToolTip="Clear" Click="PauseNotifications_Click"/>
                <Button Content="⨯" Style="{StaticResource DarkButton}" ToolTip="Pause" Click="PauseNotifications_Click"/>
                <Button Content="⨯" Style="{StaticResource DarkButton}" ToolTip="Test" Click="TestNotifications_Click"/>
            </StackPanel>
        </Border>


        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
            Background="#222"
            Height="22"
            BorderThickness="0">
            <Grid>
                <TextBlock x:Name="StatusText"
                   Text="Ready"
                   VerticalAlignment="Center"
                   Margin="8,0,0,0"
                   Foreground="White"
                   FontSize="10"/>
            </Grid>
        </Border>

        <!-- A Data grid would have been here, but we want to experiment with a list view. -->
        <ListView Name="notificationsListView" ItemsSource="{Binding NotificationListEntries}"
                  Background="#1A1A1A"
                  Foreground="White"
                  FontSize="10">

            <ListView.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Background" Value="#1A1A1A"/>
                    <!-- Track background -->
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="BorderBrush" Value="Black"/>


                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="#1A1A1A">
                                    <Track Name="PART_Track"
                               IsDirectionReversed="True">
                                        <Track.Thumb>
                                            <Thumb Background="Black" BorderBrush="Black" BorderThickness="0.5"/>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>



                </Style>
            </ListView.Resources>
            
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Timestamp}" Margin="3,1,1,1"/>
                        <TextBlock Text="{Binding Operation}" Margin="5,1,1,1"/>
                        <TextBlock Text="{Binding Status}" Margin="5,1,1,1"/>
                        <TextBlock Text="{Binding Detail}" Margin="5,1,1,1"/>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

    </DockPanel>

</Window>
