<Window x:Class="phoenix_prototype.NewEmailConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Email Configuration"
        Height="300" Width="450"
        Background="#1A1A1A"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <!-- Form -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- =======================
             FORM AREA
           ======================= -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Service Name -->
            <Label Content="Service Name:"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"/>
            <TextBox Grid.Column="1"
                     Margin="0,0,0,5"
                     Width="250"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="#555"
                     x:Name="TxtServiceName"/>

            <!-- Host -->
            <Label Content="Host:"
                   Grid.Row="1"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="0,0,10,10"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                     Margin="0,0,0,5"
                     Width="250"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="#555"
                     x:Name="TxtHost"/>

            <!-- Port -->
            <Label Content="Port:"
                   Grid.Row="2"
                   Foreground="White"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Width="250"
                     Background="#333"
                     Foreground="White"
                     BorderBrush="#555"
                     x:Name="TxtPort"/>
        </Grid>

        <!-- =======================
             BUTTON BAR
           ======================= -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">

            <Button Content="Add"
                    Width="80"
                    Margin="0,0,10,0"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    Click="AddEmailConfig_Click"/>

            <Button Content="Cancel"
                    Width="80"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    Click="CancelAddEmailConfig_Click"/>
        </StackPanel>
    </Grid>
</Window>
