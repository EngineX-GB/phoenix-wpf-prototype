<Window x:Class="phoenix_prototype.NewEmailAccount"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:phoenix_prototype"
        mc:Ignorable="d"
        Title="Add Email Account"
        Height="300" Width="450"
        Background="#1A1A1A"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <!-- Form -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- =======================
            FORM AREA
          ======================= -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Service Name -->
            <Label Content="Username:"
                  Foreground="White"
                  VerticalAlignment="Center"
                  Margin="0,0,10,10"/>
            <TextBox Grid.Column="1"
                    Margin="0,0,0,5"
                    Width="250"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    x:Name="TxtUsername"/>

            <!-- Host -->
            <Label Content="Password: "
                  Grid.Row="1"
                  Foreground="White"
                  VerticalAlignment="Center"
                  Margin="0,0,10,10"/>
            <TextBox Grid.Row="1" Grid.Column="1"
                    Margin="0,0,0,5"
                    Width="250"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    x:Name="TxtPassword"/>

            <!-- Formal name -->
            <Label Content="Formal Name:"
                  Grid.Row="2"
                  Foreground="White"
                  VerticalAlignment="Center"
                  Margin="0,0,10,0"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                    Width="250"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    x:Name="TxtFormalName"/>


            <!--Email Config ID -->
            <Label Content="Email Config ID:"
                  Grid.Row="3"
                  Foreground="White"
                  VerticalAlignment="Center"
                  Margin="0,0,10,0"/>
            <TextBox Grid.Row="3" Grid.Column="1"
                    Width="250"
                    Background="#333"
                    Foreground="White"
                    BorderBrush="#555"
                    x:Name="TxtEmailConfigId"/>
        </Grid>

        <!-- =======================
            BUTTON BAR
          ======================= -->
        <StackPanel Grid.Row="1"
                   Orientation="Horizontal"
                   HorizontalAlignment="Right"
                   Margin="0,20,0,0">

            <Button Content="Add"
                   Width="80"
                   Margin="0,0,10,0"
                   Background="#333"
                   Foreground="White"
                   BorderBrush="#555"
                   Click="AddEmailAccount_Click"/>

            <Button Content="Cancel"
                   Width="80"
                   Background="#333"
                   Foreground="White"
                   BorderBrush="#555"
                   Click="CancelAddEmailAccount_Click"/>
        </StackPanel>
    </Grid>
</Window>
